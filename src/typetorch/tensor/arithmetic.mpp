export module typetorch:tensor_arithmetic;

import :tensor_core;

#include "attributes.inc"
#include "type_macros.inc"

export namespace typetorch
{

// add(Other)
template <ShapeLike ShapeKind, DType DTypeKind, Device DeviceKind, Layout LayoutKind>
template <TensorLike Other>
[[nodiscard]] TYPETORCH_HOT TYPETORCH_ALWAYS_INLINE auto Tensor<ShapeKind, DTypeKind, DeviceKind, LayoutKind>::add(Other const &other, ::torch::Scalar const &alpha) const
{
    using OtherShape = typename Other::shape;
    static_assert(BROADCAST_COMPATIBLE(ShapeKind, OtherShape),
                  "tensor shapes are not broadcast-compatible");
    using Result =
        Tensor<BROADCAST_SHAPE_T(ShapeKind, OtherShape),
               common_dtype(DTypeKind, Other::dtype),
               common_device(DeviceKind, Other::device), Layout::Any>;
    return Result::unsafe_move(unsafe_raw().add(other.unsafe_raw(), alpha));
}

// add(scalar)
template <ShapeLike ShapeKind, DType DTypeKind, Device DeviceKind, Layout LayoutKind>
[[nodiscard]] TYPETORCH_HOT inline auto Tensor<ShapeKind, DTypeKind, DeviceKind, LayoutKind>::add(::torch::Scalar const &other, ::torch::Scalar const &alpha) const
{
    return unsafe_move(unsafe_raw().add(other, alpha));
}

